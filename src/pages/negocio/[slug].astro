---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import Stars from '../../components/Stars.astro';
import Gallery from '../../components/Gallery.astro';
import PlanBadge from '../../components/PlanBadge.astro';
import ReviewForm from '../../components/ReviewForm.astro';
import { getBusiness } from '../../lib/api';
import { youtubeId } from '../../lib/youtube';

const { slug } = Astro.params;
const business = await getBusiness(slug!);

if (!business) {
  return Astro.redirect('/');
}

const videoId = youtubeId(business.video_url);
const reviews = business.reviews ?? [];
const hasContact = Boolean(business.address || business.phone || business.email);
const mapSrc = business.address
  ? `https://maps.google.com/maps?q=${encodeURIComponent(business.address)}&z=14&output=embed`
  : null;
const mapsLink = business.address
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(business.address)}`
  : null;
const telHref = business.phone ? `tel:${business.phone.replace(/\s+/g, '')}` : null;
---

<Layout title={`${business.name} · UbicaNegocios`} description={business.description ?? ''}>
  <nav class="mb-3 text-sm text-gray-500">
    <a href="/" class="hover:underline">Inicio</a>
    {
      business.categories[0] && (
        <>
          {' / '}
          <a href={`/categoria/${business.categories[0].slug}`} class="hover:underline">
            {business.categories[0].name}
          </a>
        </>
      )
    }
    {' / '}<span>{business.name}</span>
  </nav>

  <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
    <div class="flex items-center gap-3">
      {business.plan && <PlanBadge plan={business.plan} size="lg" />}
      <h1 class="text-3xl font-bold text-gray-900">{business.name}</h1>
    </div>
    {business.reviews_count > 0 && <Stars rating={business.average_rating} count={business.reviews_count} />}
  </div>

  {
    business.categories.length > 0 && (
      <div class="mb-6 flex flex-wrap gap-2">
        {business.categories.map((c) => (
          <a
            href={`/categoria/${c.slug}`}
            class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700"
          >
            {c.name}
          </a>
        ))}
        {business.subcategories.map((s) => (
          <span class="rounded-full bg-gray-100 px-3 py-1 text-xs text-gray-600">{s.name}</span>
        ))}
      </div>
    )
  }

  <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <Gallery images={business.images} name={business.name} />

      {
        business.description && (
          <div class="mt-6">
            <h2 class="mb-2 text-lg font-semibold text-gray-900">Descripción</h2>
            <p class="whitespace-pre-line text-gray-700">{business.description}</p>
          </div>
        )
      }

      {
        business.tags?.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {business.tags.map((t) => (
              <span class="rounded bg-gray-100 px-2 py-1 text-xs text-gray-600">#{t}</span>
            ))}
          </div>
        )
      }
    </div>

    <div>
      {
        videoId && (
          <div
            class={`mx-auto overflow-hidden rounded-xl bg-black ${
              business.video_orientation === 'vertical'
                ? 'aspect-[9/16] w-full max-w-xs'
                : 'aspect-video w-full'
            }`}
          >
            <iframe
              class="h-full w-full"
              src={`https://www.youtube.com/embed/${videoId}`}
              title={`Video de ${business.name}`}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          </div>
        )
      }
    </div>
  </div>

  {
    hasContact && (
      <section class="mt-10">
        <h2 class="mb-4 text-xl font-bold text-gray-900">Contacto y ubicación</h2>
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
          <div class="space-y-3 rounded-xl border border-gray-200 bg-white p-5">
            {business.address && (
              <div class="flex items-start gap-3">
                <Icon name="lucide:map-pin" class="mt-0.5 h-5 w-5 shrink-0 text-emerald-600" />
                <div>
                  <p class="text-gray-800">{business.address}</p>
                  {mapsLink && (
                    <a
                      href={mapsLink}
                      target="_blank"
                      rel="noopener"
                      class="mt-1 inline-flex items-center gap-1 text-sm text-emerald-600 hover:underline"
                    >
                      Cómo llegar
                      <Icon name="lucide:external-link" class="h-3.5 w-3.5" />
                    </a>
                  )}
                </div>
              </div>
            )}
            {business.phone && (
              <div class="flex items-center gap-3">
                <Icon name="lucide:phone" class="h-5 w-5 shrink-0 text-emerald-600" />
                <a href={telHref!} class="text-gray-800 hover:text-emerald-600">
                  {business.phone}
                </a>
              </div>
            )}
            {business.email && (
              <div class="flex items-center gap-3">
                <Icon name="lucide:mail" class="h-5 w-5 shrink-0 text-emerald-600" />
                <a href={`mailto:${business.email}`} class="text-gray-800 hover:text-emerald-600">
                  {business.email}
                </a>
              </div>
            )}
          </div>

          {mapSrc && (
            <div class="overflow-hidden rounded-xl border border-gray-200">
              <iframe
                src={mapSrc}
                title={`Ubicación de ${business.name}`}
                class="h-72 w-full"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              />
            </div>
          )}
        </div>
      </section>
    )
  }

  <section class="mt-12">
    <h2 class="mb-4 text-xl font-bold text-gray-900">
      Reseñas {business.reviews_count > 0 && `(${business.reviews_count})`}
    </h2>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
      <div class="space-y-3">
        {
          reviews.length > 0 ? (
            reviews.map((r) => (
              <div class="rounded-xl border border-gray-200 bg-white p-4">
                <div class="flex items-center justify-between">
                  <span class="font-medium text-gray-900">{r.author_name}</span>
                  <Stars rating={r.rating} />
                </div>
                <p class="mt-1 text-gray-700">{r.body}</p>
                <p class="mt-1 text-xs text-gray-400">
                  {new Date(r.created_at).toLocaleDateString('es-MX')}
                </p>
              </div>
            ))
          ) : (
            <p class="text-gray-500">Sé el primero en dejar una reseña.</p>
          )
        }
      </div>

      <ReviewForm slug={business.slug} />
    </div>
  </section>
</Layout>
